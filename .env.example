# Template environment variables. Copy to .env if you want to override
# the defaults baked into docker-compose.yml.
#   cp .env.example .env
#
# These match the compose defaults; the stack runs fine without a .env.

# --- PostgreSQL (OLTP source) ---
PG_HOST=postgres
PG_PORT=5432
PG_DB=minimarket
PG_USER=minimarket
PG_PASSWORD=minimarket

# --- ClickHouse (Data Warehouse) ---
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=analytics
CLICKHOUSE_RAW_DB=raw

# --- Airflow UI ---
# default login: admin / admin   ->  http://localhost:8080
